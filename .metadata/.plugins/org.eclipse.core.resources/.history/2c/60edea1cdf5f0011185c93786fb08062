<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>Student Report</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .card { border-radius: 12px; border: none; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
        .stat-box { text-align: center; padding: 16px; border-radius: 10px; }
        .stat-num { font-size: 2rem; font-weight: 600; }
    </style>
</head>
<body>
<div class="container py-4" style="max-width: 700px;">

    <a href="/" class="btn btn-outline-secondary mb-3">← Back</a>

    <div th:if="${student == null}" class="alert alert-danger">Student not found.</div>

    <div th:if="${student != null}">
        <div class="card p-4 mb-4">
            <h4 class="fw-bold mb-1" th:text="${student.name}">Student Name</h4>
            <p class="text-muted mb-0">Student ID: <span th:text="${student.id}"></span></p>
        </div>

        <!-- Stats Row -->
        <div class="row g-3 mb-4">
            <div class="col-4">
                <div class="stat-box bg-primary bg-opacity-10">
                    <div class="stat-num text-primary"
                         th:text="${#numbers.formatDecimal(student.average, 1, 1)}">0.0</div>
                    <div class="text-muted small">Average</div>
                </div>
            </div>
            <div class="col-4">
                <div class="stat-box bg-success bg-opacity-10">
                    <div class="stat-num text-success"
                         th:text="${#numbers.formatDecimal(student.highest, 1, 1)}">0.0</div>
                    <div class="text-muted small">Highest</div>
                </div>
            </div>
            <div class="col-4">
                <div class="stat-box bg-danger bg-opacity-10">
                    <div class="stat-num text-danger"
                         th:text="${#numbers.formatDecimal(student.lowest, 1, 1)}">0.0</div>
                    <div class="text-muted small">Lowest</div>
                </div>
            </div>
        </div>

        <!-- Grades List -->
        <div class="card p-4">
            <h6 class="fw-bold mb-3">All Grades</h6>
            <div th:if="${student.grades.isEmpty()}" class="text-muted">No grades recorded yet.</div>
            <div th:if="${!student.grades.isEmpty()}">
                <div th:each="g, i : ${student.grades}" class="mb-2">
                    <div class="d-flex align-items-center gap-2">
                        <small class="text-muted" style="width: 60px">Test <span th:text="${i.index + 1}"></span></small>
                        <div class="progress flex-grow-1" style="height: 20px;">
                            <div class="progress-bar"
                                 th:classappend="${g >= 75} ? 'bg-success' : (${g >= 50} ? 'bg-warning' : 'bg-danger')"
                                 role="progressbar"
                                 th:style="'width:' + ${g} + '%'"
                                 th:text="${g}">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>