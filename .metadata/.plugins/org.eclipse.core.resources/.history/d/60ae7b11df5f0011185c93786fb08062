<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>Student Grade Tracker</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .card { border-radius: 12px; border: none; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
        .stat-card { text-align: center; padding: 20px; }
        .stat-number { font-size: 2rem; font-weight: 600; }
        .table th { background-color: #f1f3f5; }
        .badge-grade { font-size: 0.85rem; }
    </style>
</head>
<body>
<div class="container py-4">

    <!-- Header -->
    <div class="mb-4">
        <h2 class="fw-bold">🎓 Student Grade Tracker</h2>
        <p class="text-muted">Manage students and track their grades</p>
    </div>

    <!-- Alerts -->
    <div th:if="${success}" class="alert alert-success alert-dismissible fade show" role="alert">
        <span th:text="${success}"></span>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <div th:if="${error}" class="alert alert-danger alert-dismissible fade show" role="alert">
        <span th:text="${error}"></span>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>

    <!-- Summary Stats -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card stat-card">
                <div class="stat-number text-primary" th:text="${totalStudents}">0</div>
                <div class="text-muted">Total Students</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card">
                <div class="stat-number text-success" th:text="${#numbers.formatDecimal(classAverage, 1, 1)}">0.0</div>
                <div class="text-muted">Class Average</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card">
                <div class="stat-number text-warning"
                     th:text="${topStudent != null} ? ${topStudent.name} : 'N/A'">N/A</div>
                <div class="text-muted">Top Student</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card">
                <div class="stat-number text-danger"
                     th:text="${bottomStudent != null} ? ${bottomStudent.name} : 'N/A'">N/A</div>
                <div class="text-muted">Needs Improvement</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Left: Forms -->
        <div class="col-md-4">

            <!-- Add Student Form -->
            <div class="card p-3 mb-3">
                <h6 class="fw-bold mb-3">Add New Student</h6>
                <form th:action="@{/addStudent}" method="post">
                    <div class="mb-2">
                        <input type="text" name="name" class="form-control"
                               placeholder="Enter student name" required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Add Student</button>
                </form>
            </div>

            <!-- Add Grade Form -->
            <div class="card p-3 mb-3">
                <h6 class="fw-bold mb-3">Add Grade</h6>
                <form th:action="@{/addGrade}" method="post">
                    <div class="mb-2">
                        <select name="studentId" class="form-select" required>
                            <option value="">Select student</option>
                            <option th:each="s : ${students}"
                                    th:value="${s.id}"
                                    th:text="${s.name}">Student</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <input type="number" name="grade" class="form-control"
                               placeholder="Grade (0-100)" min="0" max="100"
                               step="0.1" required>
                    </div>
                    <button type="submit" class="btn btn-success w-100">Add Grade</button>
                </form>
            </div>

            <!-- Delete Student Form -->
            <div class="card p-3">
                <h6 class="fw-bold mb-3">Delete Student</h6>
                <form th:action="@{/deleteStudent}" method="post">
                    <div class="mb-2">
                        <select name="studentId" class="form-select" required>
                            <option value="">Select student</option>
                            <option th:each="s : ${students}"
                                    th:value="${s.id}"
                                    th:text="${s.name}">Student</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-danger w-100">Delete Student</button>
                </form>
            </div>

        </div>

        <!-- Right: Student Table -->
        <div class="col-md-8">
            <div class="card p-3">
                <h6 class="fw-bold mb-3">All Students</h6>
                <div th:if="${students.isEmpty()}" class="text-muted text-center py-4">
                    No students added yet.
                </div>
                <table th:if="${!students.isEmpty()}" class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Average</th>
                            <th>Highest</th>
                            <th>Lowest</th>
                            <th>Grades</th>
                            <th>Report</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr th:each="s : ${students}">
                            <td th:text="${s.id}"></td>
                            <td class="fw-medium" th:text="${s.name}"></td>
                            <td>
                                <span class="badge bg-primary"
                                      th:text="${#numbers.formatDecimal(s.average, 1, 1)}"></span>
                            </td>
                            <td>
                                <span class="badge bg-success"
                                      th:text="${#numbers.formatDecimal(s.highest, 1, 1)}"></span>
                            </td>
                            <td>
                                <span class="badge bg-danger"
                                      th:text="${#numbers.formatDecimal(s.lowest, 1, 1)}"></span>
                            </td>
                            <td>
                                <span th:if="${s.grades.isEmpty()}" class="text-muted">No grades</span>
                                <span th:each="g, i : ${s.grades}"
                                      class="badge bg-secondary badge-grade me-1"
                                      th:text="${g}"></span>
                            </td>
                            <td>
                                <a th:href="@{/student/{id}(id=${s.id})}"
                                   class="btn btn-sm btn-outline-primary">View</a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>